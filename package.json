{
	"name": "react-template",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@11.11.0",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"check:staged": "biome check --staged --no-errors-on-unmatched",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,jsx,tsx,json,jsonc,css}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.3.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router": "^8.2.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"typescript": "~6.0.3",
		"vite": "^8.1.4"
	}
}
